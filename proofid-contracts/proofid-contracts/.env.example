# Wallet private key used to deploy contracts. NEVER commit your real key.
# Must be funded with testnet POL on Polygon Amoy.
PRIVATE_KEY=your_wallet_private_key_without_0x_prefix

# Polygon Amoy RPC endpoint.
RPC_URL=https://rpc-amoy.polygon.technology

# Polygonscan API key, used for automatic contract verification.
# Get one at https://polygonscan.com/myapikey (works across Polygon networks).
POLYGONSCAN_API_KEY=your_polygonscan_api_key
